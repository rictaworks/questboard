RAILS_ENV=development
RAILS_MAX_THREADS=5
RAILS_MASTER_KEY=
DATABASE_URL=postgresql://localhost/questboard
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://questboard.vercel.app
ADMIN_BASIC_AUTH_USERNAME=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me
SECRET_KEY_BASE=replace-with-random-value
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://app.example.com/auth/google/callback
RECAPTCHA_SECRET_KEY=replace-with-recaptcha-secret
